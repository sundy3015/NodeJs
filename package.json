{
  "name": "@fygame/tsnode",
  "version": "1.0.0",
  "description": "just test node ",
  "main": "lib/index.js",
  "type": "module",
  "scripts": {
    "build": " tsc --watch",
    "build:exe": "node --build-sea sea-config.json",
    "build:ci": "node  lib/index.js > out.log 2> error.log",
    "test": " cls&&node --env-file=.env --watch lib/index.js sundy",
    "start": " cls&&node --env-file=.env --watch lib/index.js sundy",
    "npmjs": "npm config set registry https://registry.npmjs.org/",
    "mirror": "npm config set registry https://registry.npmmirror.com",
    "registry": "npm config get registry"
  },
  "author": "Sundy",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^25.9.1",
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3"
  }
}
